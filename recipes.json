---
layout: null
---
{% assign recipeCounter = 1 %}
{% assign totalRecipes = site.recipes | size %}
{% assign publishedRecipes = site.recipes | where_exp: "r", "r.status != 'draft' and r.status != 'planned'" %}
{% assign publishedRecipeCount = publishedRecipes | size %}
{% assign buildDateTime = site.time | date_to_xmlschema %}

{
  "buildDateTime": {{ buildDateTime | jsonify }},
  "recipeCount": {{ totalRecipes }},
  "publishedRecipeCount": {{ publishedRecipeCount }},
  "recipes": [
    {% for post in site.recipes %}
      {
        "title": {{ post.title | jsonify }},
        "url": {{ post.url | relative_url | jsonify }},
        "status": {{ post.status | default: "published" | jsonify }},
        "reviewed": {{ post.reviewed | default: false | jsonify }},
        "difficulty": {{ post.difficulty | default: "" | jsonify }},
        "date_added": {{ post.date_added | default: "" | jsonify }},
        "categories": {{ post.categories | default: empty | jsonify }},
        "tags": {{ post.tags | default: empty | jsonify }}
        {% if post.image %},"image": {{ post.image | jsonify }}{% endif %}
        {% if post.imagecredit %},"imagecredit": {{ post.imagecredit | jsonify }}{% endif %}
      }{% if recipeCounter == totalRecipes %}{% else %},{% endif %}
      {% assign recipeCounter = recipeCounter | plus: 1 %}
    {% endfor %}
  ]
}
